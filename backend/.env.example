# Gemini API keys — one per line, numbered. Add as many as you have.
GEMINI_API_KEY_1="your-key-1"
GEMINI_API_KEY_2="your-key-2"
GEMINI_API_KEY_3="your-key-3"

# Optional tuning (defaults shown)
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_DAILY_LIMIT="20"     # requests allowed per key per day
GEMINI_COOLDOWN="60"        # seconds to rest a key after a 429
CACHE_TTL="86400"           # plan cache lifetime in seconds (24h)
LOG_LEVEL="INFO"

# ── Firebase Admin (auth + Firestore) ───────────────────────────
# Verifies Firebase ID tokens and talks to Firestore via the Admin SDK.
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_SERVICE_ACCOUNT="service-account.json"   # path relative to backend/

# ── Admin access ────────────────────────────────────────────────
# Comma-separated emails; checked against the verified Firebase token.
ADMIN_EMAILS="you@example.com"

# ── Google Cloud Text-to-Speech (optional) ──────────────────────
# A Google API key from a project where Cloud Text-to-Speech is enabled.
# If unset, the coach uses the browser's built-in speech instead.
GOOGLE_TTS_API_KEY=""
