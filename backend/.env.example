# Gemini API keys — one per line, numbered. Add as many as you have.
GEMINI_API_KEY_1="your-key-1"
GEMINI_API_KEY_2="your-key-2"
GEMINI_API_KEY_3="your-key-3"

# Optional tuning (defaults shown)
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_DAILY_LIMIT="20"     # requests allowed per key per day
GEMINI_COOLDOWN="60"        # seconds to rest a key after a 429
CACHE_TTL="86400"           # plan cache lifetime in seconds (24h)
LOG_LEVEL="INFO"

# ── Database ────────────────────────────────────────────────────
MONGO_URI="mongodb://localhost:27017"

# ── Auth ────────────────────────────────────────────────────────
SECRET_KEY="change-me-to-a-long-random-string"
ADMIN_EMAILS="you@example.com"

# ── Google OAuth + APIs ─────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
GOOGLE_OAUTH_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="GOCSPX-xxxx"
# Must EXACTLY match an "Authorized redirect URI" on the OAuth client.
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/google/callback"
# Where the backend bounces the browser after login (your frontend origin).
FRONTEND_URL="http://localhost:5173"

# ── Google Cloud Text-to-Speech (optional) ──────────────────────
# A Google API key from the SAME project where you enabled the Cloud
# Text-to-Speech API. If unset, the coach uses the browser's built-in
# speech instead (still speaks, just not the premium Google voice).
GOOGLE_TTS_API_KEY=""
